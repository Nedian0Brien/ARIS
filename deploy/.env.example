# Domain & URL
ARIS_DOMAIN=aris.lawdigest.cloud
APP_BASE_URL=https://aris.lawdigest.cloud
WEB_PORT=3300

# Shared runtime token (must match backend and web)
RUNTIME_API_TOKEN=change-this-runtime-token

# Web auth/admin
AUTH_JWT_SECRET=replace-with-very-long-random-secret-at-least-32-characters
ARIS_ADMIN_EMAIL=admin@example.com
ARIS_ADMIN_PASSWORD=change-me

# DB
POSTGRES_DB=aris
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# SSH fallback defaults
SSH_BASE_COMMAND=ssh ubuntu@your-server
SSH_LINK_TTL_SECONDS=300

# Optional overrides
AUTH_TOKEN_TTL_SECONDS=900
