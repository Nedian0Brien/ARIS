# Domain & URL
ARIS_DOMAIN=aris.lawdigest.cloud
APP_BASE_URL=https://aris.lawdigest.cloud
WEB_PORT=3300

# Workspace & Isolation
# Set this to the absolute path on your HOST where your projects are located.
# The agent will be able to access and modify files under this directory.
HOST_PROJECTS_ROOT=/home/ubuntu/project

# Shared runtime token (must match backend and web)
RUNTIME_API_TOKEN=__SET_RUNTIME_API_TOKEN__

# Web auth/admin
AUTH_JWT_SECRET=__SET_STRONG_JWT_SECRET_MIN_32_CHARS__
ARIS_ADMIN_EMAIL=admin@aris.local
ARIS_ADMIN_PASSWORD=__SET_STRONG_ADMIN_PASSWORD__
ARIS_ADMIN_2FA_SECRET=__OPTIONAL_BASE32_TOTP_SECRET__
ARIS_ADMIN_2FA_EMAIL=false

# SMTP Configuration (required for Email 2FA)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=ARIS <noreply@aris.local>

# DB
POSTGRES_DB=aris
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__SET_POSTGRES_PASSWORD__

# SSH fallback defaults
SSH_BASE_COMMAND=ssh ubuntu@your-server
SSH_LINK_TTL_SECONDS=300

# Optional overrides
AUTH_TOKEN_TTL_SECONDS=900
