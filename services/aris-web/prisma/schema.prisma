generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  operator
  viewer
}

enum KnowledgeAssetKind {
  decision
  task_outcome
  command_recipe
  debug_case
  deployment_record
  project_memory
  user_preference
  external_note
}

enum KnowledgeAssetStatus {
  candidate
  confirmed
  dismissed
}

enum KnowledgeAssetScope {
  global
  project
  chat
}

enum KnowledgeSensitivity {
  normal
  redacted
  sensitive
}

enum KnowledgeSourceType {
  session_chat_event
  session_run
  chat
  project
  external
}

enum AskMessageRole {
  user
  assistant
  system
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  role         UserRole     @default(viewer)
  twoFactorSecret String?   // TOTP secret
  twoFactorEmailEnabled Boolean @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  sessions     AuthSession[]
  auditLogs    AuditLog[]
  preferences  UiPreference?
  projects     Project[]
  workspaces   Workspace[]
  sessionMetadata SessionMetadata[]
  chats         Chat[]
  knowledgeAssets KnowledgeAsset[]
  askThreads    AskThread[]
  trustedDevices TrustedDevice[]
  emailTokens    EmailVerificationToken[]
}

model Project {
  id          String   @id
  userId      String
  path        String
  alias       String?
  isPinned    Boolean  @default(false)
  includeInAskIndex Boolean @default(true)
  lastReadAt  DateTime?
  panelLayoutJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaces  Workspace[]

  @@unique([userId, path])
  @@index([userId, updatedAt])
}

model Workspace {
  id            String   @id @default(cuid())
  userId        String
  projectId     String
  title         String   @default("Default workspace")
  layoutJson    Json?
  activePanelId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  panels        WorkspacePanel[]

  @@unique([userId, projectId, title])
  @@index([userId, projectId, updatedAt])
}

model WorkspacePanel {
  id               String   @id @default(cuid())
  workspaceId      String
  panelId          String
  chatId           String
  runtimeSessionId String?
  branch           String?
  worktreePath     String?
  order            Int      @default(0)
  meta             Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chat             Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, panelId])
  @@unique([workspaceId, chatId])
  @@index([chatId])
  @@index([runtimeSessionId])
}

model SessionMetadata {
  sessionId String
  userId    String
  alias     String?
  isPinned  Boolean @default(false)
  lastReadAt DateTime?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@index([userId])
}

model Chat {
  id             String   @id @default(cuid())
  projectId      String
  userId         String
  agent          String   @default("codex")
  title          String
  isPinned       Boolean  @default(false)
  isDefault      Boolean  @default(false)
  includeInAskIndex Boolean @default(true)
  threadId       String?
  model          String?
  geminiMode     String?
  modelReasoningEffort String?
  latestPreview  String   @default("")
  latestEventId  String?
  latestEventAt  DateTime?
  latestEventIsUser Boolean @default(false)
  latestHasErrorSignal Boolean @default(false)
  lastReadAt     DateTime?
  lastReadEventId String?
  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs           SessionRun[]
  events         SessionChatEvent[]
  workspacePanels WorkspacePanel[]

  @@index([projectId, userId, isPinned, lastActivityAt])
  @@index([userId, updatedAt])
}

model SessionRun {
  id           String   @id @default(cuid())
  sessionId    String
  chatId       String
  agent        String
  model        String?
  status       String   @default("running")
  errorMessage String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chat         Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  events       SessionChatEvent[]

  @@index([chatId, status])
  @@index([sessionId, chatId, startedAt])
}

model SessionChatEvent {
  id        String   @id @default(cuid())
  sessionId String
  chatId    String
  runId     String?
  type      String
  title     String?
  text      String
  meta      Json?
  seq       Int
  createdAt DateTime @default(now())
  chat      Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  run       SessionRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([chatId, seq])
  @@index([sessionId, chatId, seq])
  @@index([chatId, createdAt])
}

model KnowledgeAsset {
  id          String                 @id @default(cuid())
  userId      String
  kind        KnowledgeAssetKind
  title       String
  summary     String
  body        String
  status      KnowledgeAssetStatus   @default(candidate)
  scope       KnowledgeAssetScope    @default(chat)
  projectId   String?
  chatId      String?
  runId       String?
  confidence  Float                  @default(0.5)
  sensitivity KnowledgeSensitivity   @default(normal)
  tags        String[]               @default([])
  dedupeKey   String?                @unique
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceRefs  KnowledgeSourceRef[]

  @@index([userId, status, kind, updatedAt])
  @@index([userId, projectId, updatedAt])
  @@index([chatId])
}

model KnowledgeSourceRef {
  id         String              @id @default(cuid())
  assetId    String
  sourceType KnowledgeSourceType
  sourceId   String
  projectId  String?
  chatId     String?
  runId      String?
  eventSeq   Int?
  label      String?
  snippet    String?
  createdAt  DateTime            @default(now())
  asset      KnowledgeAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, sourceType, sourceId])
  @@index([sourceType, sourceId])
  @@index([chatId, eventSeq])
}

model AskThread {
  id        String       @id @default(cuid())
  userId    String
  title     String       @default("Ask ARIS")
  status    String       @default("active")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AskMessage[]

  @@index([userId, updatedAt])
}

model AskMessage {
  id        String         @id @default(cuid())
  threadId  String
  role      AskMessageRole
  content   String
  sources   Json?
  meta      Json?
  createdAt DateTime       @default(now())
  thread    AskThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  deviceFingerprint String @unique
  name      String?
  trustedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuthSession {
  id        String    @id @default(cuid())
  userId    String
  jti       String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  payloadJson  Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([userId, createdAt])
}

model UiPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  density        String   @default("compact")
  colorMode      String   @default("light")
  customAiModels Json?
  providerModelSelections Json?
  openAiApiKeyEncrypted String?
  claudeApiKeyEncrypted String?
  geminiApiKeyEncrypted String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
