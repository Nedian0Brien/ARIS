generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  operator
  viewer
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  role         UserRole     @default(viewer)
  twoFactorSecret String?   // TOTP secret
  twoFactorEmailEnabled Boolean @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  sessions     AuthSession[]
  auditLogs    AuditLog[]
  preferences  UiPreference?
  workspaces   Workspace[]
  sessionMetadata SessionMetadata[]
  sessionChats SessionChat[]
  trustedDevices TrustedDevice[]
  emailTokens    EmailVerificationToken[]
}

model Workspace {
  id          String   @id
  userId      String
  path        String
  alias       String?
  isPinned    Boolean  @default(false)
  lastReadAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, path])
  @@index([userId, updatedAt])
}

model SessionMetadata {
  sessionId String
  userId    String
  alias     String?
  isPinned  Boolean @default(false)
  lastReadAt DateTime?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@index([userId])
}

model SessionChat {
  id             String   @id @default(cuid())
  sessionId      String
  userId         String
  agent          String   @default("codex")
  title          String
  isPinned       Boolean  @default(false)
  isDefault      Boolean  @default(false)
  threadId       String?
  model          String?
  geminiMode     String?
  modelReasoningEffort String?
  latestPreview  String   @default("")
  latestEventId  String?
  latestEventAt  DateTime?
  latestEventIsUser Boolean @default(false)
  latestHasErrorSignal Boolean @default(false)
  lastReadAt     DateTime?
  lastReadEventId String?
  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs           SessionRun[]
  events         SessionChatEvent[]

  @@index([sessionId, userId, isPinned, lastActivityAt])
  @@index([userId, updatedAt])
}

model SessionRun {
  id           String   @id @default(cuid())
  sessionId    String
  chatId       String
  agent        String
  model        String?
  status       String   @default("running")
  errorMessage String?
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  chat         SessionChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  events       SessionChatEvent[]

  @@index([chatId, status])
  @@index([sessionId, chatId, startedAt])
}

model SessionChatEvent {
  id        String   @id @default(cuid())
  sessionId String
  chatId    String
  runId     String?
  type      String
  title     String?
  text      String
  meta      Json?
  seq       Int
  createdAt DateTime @default(now())
  chat      SessionChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  run       SessionRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([chatId, seq])
  @@index([sessionId, chatId, seq])
  @@index([chatId, createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  deviceFingerprint String @unique
  name      String?
  trustedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuthSession {
  id        String    @id @default(cuid())
  userId    String
  jti       String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  payloadJson  Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([userId, createdAt])
}

model UiPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  density        String   @default("compact")
  colorMode      String   @default("light")
  customAiModels Json?
  providerModelSelections Json?
  openAiApiKeyEncrypted String?
  claudeApiKeyEncrypted String?
  geminiApiKeyEncrypted String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
