# App
NEXT_PUBLIC_APP_NAME=ARIS
APP_BASE_URL=http://localhost:3000

# Auth
AUTH_JWT_SECRET=replace-with-very-long-random-secret
AUTH_TOKEN_TTL_SECONDS=900
AUTH_COOKIE_NAME=aris_session

# Bootstrap admin
ARIS_ADMIN_EMAIL=admin@example.com
ARIS_ADMIN_PASSWORD=change-me

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aris

# Runtime Integration
HAPPY_SERVER_URL=https://api.cluster-fluster.com
HAPPY_SERVER_TOKEN=

# SSH fallback
SSH_BASE_COMMAND=ssh ubuntu@your-server
SSH_LINK_TTL_SECONDS=300
