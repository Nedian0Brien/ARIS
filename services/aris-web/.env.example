# App
NEXT_PUBLIC_APP_NAME=ARIS
APP_BASE_URL=http://localhost:3000

# Auth
AUTH_JWT_SECRET=__SET_STRONG_JWT_SECRET_MIN_32_CHARS__
AUTH_TOKEN_TTL_SECONDS=900
AUTH_TOKEN_REMEMBER_TTL_SECONDS=2592000
AUTH_COOKIE_NAME=aris_session

# Bootstrap admin
ARIS_ADMIN_EMAIL=admin@aris.local
ARIS_ADMIN_PASSWORD=__SET_STRONG_ADMIN_PASSWORD__

# Database
DATABASE_URL=postgresql://postgres:__SET_POSTGRES_PASSWORD__@localhost:5432/aris

# Runtime Integration
RUNTIME_API_URL=http://localhost:4080
RUNTIME_API_TOKEN=__SET_RUNTIME_API_TOKEN__

# Legacy fallback names (kept temporarily for compatibility)
# HAPPY_SERVER_URL=http://localhost:4080
# HAPPY_SERVER_TOKEN=__SET_RUNTIME_API_TOKEN__

# SSH fallback
SSH_BASE_COMMAND=ssh ubuntu@your-server
SSH_LINK_TTL_SECONDS=300
