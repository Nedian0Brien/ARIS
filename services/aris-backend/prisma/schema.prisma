generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id             String   @id @default(uuid())
  flavor         String
  path           String
  branch         String?
  status         String   @default("idle")
  approvalPolicy String   @default("on-request")
  model          String?
  riskScore      Int      @default(20)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  messages    SessionMessage[]
  permissions Permission[]
}

model SessionChat {
  id                   String   @id
  sessionId            String
  userId               String
  agent                String
  title                String
  isPinned             Boolean
  isDefault            Boolean
  threadId             String?
  model                String?
  geminiMode           String?
  modelReasoningEffort String?
  latestPreview        String
  latestEventId        String?
  latestEventAt        DateTime?
  latestEventIsUser    Boolean
  latestHasErrorSignal Boolean
  lastReadAt           DateTime?
  lastReadEventId      String?
  lastActivityAt       DateTime
  createdAt            DateTime
  updatedAt            DateTime

  runs   SessionRun[]
  events SessionChatEvent[]

  @@index([sessionId, userId, isPinned, lastActivityAt])
  @@index([userId, updatedAt])
}

model SessionRun {
  id          String   @id @default(cuid())
  sessionId   String
  chatId      String
  agent       String
  model       String?
  status      String   @default("running")
  errorMessage String?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chat   SessionChat       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  events SessionChatEvent[]

  @@index([chatId, status])
  @@index([sessionId, chatId, startedAt])
}

model SessionChatEvent {
  id        String   @id @default(cuid())
  sessionId String
  chatId    String
  runId     String?
  type      String
  title     String?
  text      String
  meta      Json?
  seq       Int
  createdAt DateTime @default(now())

  chat SessionChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  run  SessionRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([chatId, seq])
  @@index([sessionId, chatId, seq])
  @@index([chatId, createdAt])
}

model SessionMessage {
  id        String   @id @default(uuid())
  sessionId String
  type      String
  title     String?
  text      String
  meta      Json?
  seq       Int

  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, seq])
  @@index([sessionId, seq])
  @@index([sessionId, createdAt])
}

model Permission {
  id          String    @id @default(uuid())
  sessionId   String
  chatId      String?
  agent       String
  command     String
  reason      String
  risk        String
  state       String    @default("pending")
  decision    String?
  requestedAt DateTime  @default(now())
  decidedAt   DateTime?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([state])
}
